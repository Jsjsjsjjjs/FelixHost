# =============================================================
# PteroControl — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================

# ── Database ────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/pterocontrol"

# ── Authentication ───────────────────────────────────────────
# Generate a secure random secret: openssl rand -base64 64
JWT_SECRET="replace-with-a-long-random-secret-at-least-64-characters"
# Session expiry in hours (default 24)
SESSION_EXPIRY_HOURS=24

# ── Pterodactyl API ──────────────────────────────────────────
# Your Pterodactyl panel base URL (no trailing slash)
PTERODACTYL_URL="https://panel.yourdomain.com"
# Application API key (Admin → API → Application)
PTERODACTYL_APP_KEY="ptla_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
# Client API key (Account → API Credentials → Client)
PTERODACTYL_CLIENT_KEY="ptlc_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="PteroControl"
NEXTAUTH_URL="http://localhost:3000"
NODE_ENV="development"
